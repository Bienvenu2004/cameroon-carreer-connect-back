# Backend environment variables (loaded by io.github.cdimascio.dotenv)
# Copy to .env and fill in real values for local development.

# Server
SERVER_PORT=8080

# Postgres
DB_URL=jdbc:postgresql://localhost:5432/jobconnect_cm
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace-with-a-32+-char-random-string-for-hs256-secret-key

# Mail (use Mailtrap or similar for development)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM=no-reply@jobconnect.cm

# Storage
STORAGE_BASE_DIR=./storage
PUBLIC_URL=http://localhost:8080/storage
LOGO_DIRECTORY=logos
LOGO_URL=http://localhost:8080/storage/logos

# Frontend URL — used in email links
CLIENT_URL=http://localhost:5173
